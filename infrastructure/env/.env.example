# ============================================================
# FORGË CSS — Environment Configuration
# Copy to .env.local for development
# ============================================================

# ─── Database ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=forge_css
POSTGRES_USER=forge_admin
POSTGRES_PASSWORD=your_secure_password_here

# ─── Authentication ────────────────────────────────────────────
JWT_SECRET=your_256_bit_secret_here_minimum_32_chars_required_in_production

# ─── Anthropic AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000

# ─── Optional: File Storage (for progress photos) ──────────────
# S3_BUCKET=forge-css-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── Optional: Email notifications ─────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=
# FROM_EMAIL=noreply@forgeforyou.com
